    "prisma:migrate": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "test": "jest",
    "coverage": "jest --coverage"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.7.4",
    "jest": "^30.4.2",
    "prisma": "^5.20.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
,
"jest": {
  "preset": "ts-jest",
  "testEnvironment": "node"
}
}
